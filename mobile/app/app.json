{
  "expo": {
    "name": "SmartBack",
    "slug": "smartback",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#20a38c",
          "defaultChannel": "device"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SmartBack accede alle tue foto per permetterti di scegliere l'immagine del profilo.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f7f6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "it.smartback.monitoring"
    },
    "android": {
      "package": "it.smartback.monitoring",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4849f8aa-3f37-4128-8b43-1419cf865962"
      }
    },
    "owner": "3ab"
  }
}
