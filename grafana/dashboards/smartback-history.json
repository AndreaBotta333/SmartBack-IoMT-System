      },
      "pluginVersion": "12.0.2",
      "targets": [
        {
          "query": "import \"strings\"\nbase = from(bucket: \"posture\") |> range(start: time(v: \"${alert_day_start}\"), stop: time(v: \"${alert_day_stop}\")) |> filter(fn: (r) => r._measurement == \"alerts\" and r.patient_id == \"${patient_id}\" and r.session_id == \"${session_id}\")\nactive = base |> filter(fn: (r) => r._field == \"active\") |> rename(columns: {_value: \"active\"}) |> keep(columns: [\"_time\", \"code\", \"severity\", \"active\"])\nmessages = base |> filter(fn: (r) => r._field == \"message\") |> rename(columns: {_value: \"message\"}) |> keep(columns: [\"_time\", \"code\", \"severity\", \"message\"])\njoin(tables: {active: active, messages: messages}, on: [\"_time\", \"code\", \"severity\"]) |> map(fn: (r) => ({r with alert_name: if r.code == \"POSTURE_MARKED_DEVIATION\" then \"Forte inclinazione\" else if r.code == \"POSTURE_PROLONGED_DEVIATION\" then \"Inclinazione troppo lunga\" else if r.code == \"POSTURE_OK\" then \"Postura ristabilita\" else if r.code == \"DATA_STREAM_STALE\" then \"Nessun dato dalla maglia\" else if r.code == \"DATA_STREAM_RESTORED\" then \"Trasmissione ripresa\" else if r.code == \"BATTERY_CRITICAL\" then \"Batteria critica (≤10%)\" else if r.code == \"BATTERY_LOW\" then \"Batteria bassa (≤20%)\" else if r.code == \"BATTERY_RECOVERED\" then \"Batteria recuperata (>20%)\" else if r.code == \"ACC_SEQUENCE_GAP\" then \"Pacchetti saltati\" else if r.code == \"DATA_LOSS\" then \"Perdita dichiarata dalla maglia\" else \"Errore non classificato\", message: if r.code == \"POSTURE_MARKED_DEVIATION\" then \"Superata la soglia di inclinazione elevata\" else if r.code == \"POSTURE_PROLONGED_DEVIATION\" then \"Inclinazione mantenuta oltre il tempo consentito\" else if r.code == \"POSTURE_OK\" then \"Postura tornata entro i limiti\" else if r.code == \"DATA_STREAM_STALE\" then \"La maglia ha interrotto la trasmissione\" else if r.code == \"DATA_STREAM_RESTORED\" then \"La maglia ha ripreso a trasmettere\" else if r.code == \"BATTERY_CRITICAL\" then \"Carica residua pari o inferiore al 10%\" else if r.code == \"BATTERY_LOW\" then \"Carica residua tra 11% e 20%\" else if r.code == \"BATTERY_RECOVERED\" then \"Carica nuovamente superiore al 20%\" else if r.code == \"ACC_SEQUENCE_GAP\" then \"Rilevato un salto nella sequenza dei pacchetti\" else if r.code == \"DATA_LOSS\" then \"La maglia ha segnalato una perdita di dati\" else if strings.strlen(v: r.message) > 70 then strings.substring(v: r.message, start: 0, end: 70) + \"…\" else r.message}))  |> keep(columns: [\"_time\", \"alert_name\", \"active\", \"message\"]) |> group() |> sort(columns: [\"_time\"], desc: true) |> limit(n: 100)",
          "refId": "A"
        }
      ],
      "title": "Alert della sessione selezionata",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_measurement": true,
              "_start": true,
              "_stop": true,
              "device_id": true,
              "patient_id": true,
              "result": true,
              "severity": true,
              "session_id": true,
              "table": true
            },
            "indexByName": {
              "_time": 0,
              "alert_name": 1,
              "active": 2,
              "message": 3
            },
            "renameByName": {
              "_time": "Ora",
              "active": "Stato",
              "alert_name": "Tipo alert",
              "message": "Messaggio"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
