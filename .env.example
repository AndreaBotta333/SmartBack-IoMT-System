# Copiare questo file in .env e impostare l'indirizzo IP corrente del computer.
HOST_IP=192.168.1.100
GRAFANA_PUBLIC_URL=http://localhost:3000/grafana/
GRAFANA_SIGNOUT_URL=http://localhost:3000/grafana-logout
API_PORT=8000

# Associazione server-side e identita della sorgente simulata.
SMARTSHIRT_PATIENT_ID=patient-demo-001
# Opzionale: lasciare vuoto per gestire le maglie simulate dalla Home medica.
SIMULATOR_DEVICE_ID=

# Stabilizzazione server-side del segnale e watchdog del flusso.
POSTURE_EMA_ALPHA=0.5
POSTURE_HYSTERESIS_DEG=2
DATA_STALE_SECONDS=10
MODERATE_DEVIATION_DEG=10
MARKED_DEVIATION_DEG=20
MODERATE_ROLL_DEG=10
MARKED_ROLL_DEG=20

# Emulazione fedele dell'output MQTT dell'ESP32.
SIMULATION_SCENARIO=day-cycle
SIMULATOR_SAMPLING_FREQUENCY_HZ=25
SIMULATOR_SAMPLES_PER_PACKET=16
SIMULATOR_BATTERY_INTERVAL_SECONDS=30
SIMULATION_SEED=20260717
# 0 = nessuna perdita. Es. 10 salta ogni decimo ACC_GYRO e prova gli alert.
SIMULATOR_DROP_EVERY_N_PACKETS=0
SIMULATOR_REPORT_DATALOSS_ON_DROP=true

# Codice dimostrativo usato per verificare la registrazione del ruolo Medico.
MEDICAL_REGISTRATION_CODE=SMARTBACK-MED-2026

# Credenziali locali di sviluppo: sostituire prima di ambienti condivisi o di produzione.
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me
INFLUXDB_ORG=smartback
INFLUXDB_BUCKET=posture
INFLUXDB_TOKEN=change-me-with-a-long-random-token
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=smartback-dev-password
